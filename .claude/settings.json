{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./**/*.jks)",
      "Read(./**/*.keystore)",
      "Edit(./**/*.jks)",
      "Edit(./**/*.keystore)",
      "Write(./**/*.jks)",
      "Write(./**/*.keystore)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Edit(./credentials/**)",
      "Write(./secrets/**)",
      "Edit(./game/builds/**)",
      "Write(./game/builds/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(gh pr merge:*)"
    ],
    "allow": [
      "Edit(./game/scenes/**)",
      "Edit(./game/scripts/**)",
      "Edit(./game/data/**)",
      "Edit(./game/assets/**)",
      "Edit(./game/shaders/**)",
      "Edit(./docs/**)",
      "Edit(./AGENTS.md)",
      "Edit(./BLUEPRINT.md)",
      "Edit(./TASKBOARD.md)",
      "Edit(./RUNBOOK.md)",
      "Edit(./README.md)",
      "Edit(./CLAUDE.md)",
      "Edit(./HARNESS_FEEDBACK.md)",
      "Bash(/Applications/Godot.app/Contents/MacOS/Godot --headless*)"
    ]
  }
}
