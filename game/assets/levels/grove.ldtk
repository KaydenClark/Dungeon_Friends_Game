       "px": [
        64,
        48
       ],
       "fieldInstances": [
        {
         "__identifier": "Lines",
         "__type": "Array<String>",
         "__value": [
          "You came through the forest? Then you saw it - the browning.",
          "The dragon's shadow reaches farther than its wings, and my grove",
          "is dying under it. I don't bonk things; things want to live, mostly.",
          "But you're headed up the mountain, aren't you? Then I'm coming.",
          "Point me at what's withered and keep the slimes off my back."
         ],
         "__tile": null,
         "defUid": 1000,
         "realEditorValues": [
          {
           "id": "V_String",
           "params": [
            "You came through the forest? Then you saw it - the browning."
           ]
          },
          {
           "id": "V_String",
           "params": [
            "The dragon's shadow reaches farther than its wings, and my grove"
           ]
          },
          {
           "id": "V_String",
           "params": [
            "is dying under it. I don't bonk things; things want to live, mostly."
           ]
          },
          {
           "id": "V_String",
           "params": [
            "But you're headed up the mountain, aren't you? Then I'm coming."
           ]
          },
          {
           "id": "V_String",
           "params": [
            "Point me at what's withered and keep the slimes off my back."
           ]
          }
         ]
        },
